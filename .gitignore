# ==============================================================================
# NTIRE 2026 Image Super-Resolution (×4) — .gitignore
# Team 29: Anant_SVNIT (FreqFusionSR)
# ==============================================================================
# Keep: all source code, configs, scripts, factsheet, utils, README, LICENSE
# Exclude: model weights, datasets, outputs, logs, build artifacts
# ==============================================================================

# ==============================================================================
# MODEL WEIGHTS (large binary files — download links in model_zoo/)
# ==============================================================================
*.pth
*.pt
*.ckpt
*.bin
*.safetensors
*.onnx

# Mamba wheels (pre-compiled)
mamba_wheels/
*.whl

# ==============================================================================
# PRETRAINED / CHECKPOINT DIRECTORIES
# ==============================================================================
pretrained/
checkpoints/

# Keep the model_zoo download link files
!model_zoo/
!model_zoo/**/*.txt

# ==============================================================================
# DATASETS (users download separately)
# ==============================================================================
dataset/
data/
DIV2K*/
Flickr2K*/

# Image files in any data directories
data/**/*.png
data/**/*.jpg
dataset/**/*.png
dataset/**/*.jpg

# ==============================================================================
# OUTPUTS / RESULTS / SUBMISSIONS
# ==============================================================================
outputs/
results/
NTIRE2026-ImageSRx4/
submit*/
*.zip

# ==============================================================================
# LOGS
# ==============================================================================
logs/
runs/
*.log
wandb/

# ==============================================================================
# PYTHON ARTIFACTS
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ==============================================================================
# VIRTUAL ENVIRONMENTS
# ==============================================================================
venv/
ENV/
env/
.venv/
.conda/

# ==============================================================================
# IDE & EDITOR
# ==============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.project

# ==============================================================================
# JUPYTER
# ==============================================================================
.ipynb_checkpoints/

# ==============================================================================
# OS FILES
# ==============================================================================
.DS_Store
Thumbs.db
desktop.ini

# ==============================================================================
# CACHE & TEMP
# ==============================================================================
*.cache
.pytest_cache/

# ==============================================================================
# TEMPORARY / ANALYSIS FILES
# ==============================================================================
analyze_dat.py
analyze_dat_simple.py
dat_analysis.txt
test_output.txt
scripts/breakdown.txt
scripts/param_sweep.txt
scripts/phase*_results.txt
scripts/phase*_output.txt
scripts/phase1_final_results.txt

# ==============================================================================
# LARGE FILES (PDFs, compiled factsheets)
# ==============================================================================
NTIRE.pdf
NTIRE_2026_Image_Super_Resolution__x4__Challenge_Factsheet.pdf
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.out
*.synctex.gz

# ==============================================================================
# KEEP THESE (tracked files)
# ==============================================================================
!.gitignore
!.gitkeep
!README.md
!LICENSE
!requirements.txt
!test.py
!eval.py
!train.py
